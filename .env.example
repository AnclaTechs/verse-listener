# Copy this file to .env and add your real API key.

OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_ORG_ID=

VERSE_LISTENER_STT_BACKEND=openai_realtime
VERSE_LISTENER_AUDIO_BACKEND=auto

# For transcription-only, use a transcribe model here.
# Do not switch this to gpt-realtime-1.5 unless you want audio responses/voice-agent behavior.
OPENAI_REALTIME_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_LANGUAGE=en
OPENAI_REALTIME_INPUT_RATE=24000
OPENAI_REALTIME_NOISE_REDUCTION=near_field
OPENAI_REALTIME_VAD_THRESHOLD=0.5
OPENAI_REALTIME_VAD_PREFIX_PADDING_MS=300
OPENAI_REALTIME_VAD_SILENCE_DURATION_MS=500
OPENAI_REALTIME_INCLUDE_LOGPROBS=false

OPENAI_REALTIME_PROMPT=This is a Christian sermon transcription. Prefer Bible book names and scripture references. Use clean punctuation and standard verse notation when clear.
